rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'crowns']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             data.photoURL is string &&
             data.crowns is int &&
             data.crowns >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt']) &&
             data.userId is string &&
             data.items is list &&
             data.total is number &&
             data.status in ['pending', 'preparing', 'ready', 'delivered'] &&
             data.createdAt is timestamp;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidOrder(request.resource.data);
      allow update: if false; // Orders are immutable once placed for users
      allow delete: if false;
    }

    // Rewards (Publicly readable)
    match /rewards/{rewardId} {
      allow read: if true;
      allow write: if false; // Only admin can manage rewards
    }
  }
}
